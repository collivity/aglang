// aglang self-spec — keeps this repository aligned with its own architecture rules.

node node_runtime : agent_runtime {
  trust: trusted
}

node github_actions : ci_runner {
  trust: trusted
}

node npm_registry : package_registry {
  trust: trusted
  auth: api_key
}

node github_pages : static_host {
  trust: trusted
  auth: oauth2
}

node github_releases : release_host {
  trust: trusted
  auth: oauth2
}

component CliCompiler {
  runs_on: node_runtime
  paths: "src/index.ts"
}

component LanguageFrontend {
  runs_on: node_runtime
  paths: "src/{ast,checker,importer,import-openapi,import-tf,lexer,parser}.ts"
}

component SmtBackend {
  runs_on: node_runtime
  paths: "src/smt/**/*.ts"
}

component RuntimeGate {
  runs_on: node_runtime
  paths: "src/runtime/{contract-gate,delta-assert,diff-parser,diagnostic,extraction-cache,gate}.ts"
}

component ExtractorAnalyzers {
  runs_on: node_runtime
  paths: "src/analyzers/**/*.ts"
}

component GraphProjection {
  runs_on: node_runtime
  paths: "src/runtime/graph-projection.ts"
}

component Emitters {
  runs_on: node_runtime
  paths: "src/emitters/**/*.ts"
}

component SpecGenerator {
  runs_on: node_runtime
  paths: "src/generate.ts"
}

component DocsSite {
  runs_on: node_runtime
  paths: "{docs,site,scripts}/**/*.{md,ts,js,mjs}"
}

component PackageMetadata {
  runs_on: node_runtime
  paths: "{package.json,package-lock.json}"
}

component AgentSkill {
  runs_on: node_runtime
  paths: "skills/aglang/SKILL.md"
}

component AgentSkillInstaller {
  runs_on: node_runtime
  paths: "scripts/postinstall-agent-skill.mjs"
}

component ReadmeDocs {
  runs_on: node_runtime
  paths: "README.md"
}

component CliReferenceDocs {
  runs_on: node_runtime
  paths: "docs/cli/reference.md"
}

component PublicDocs {
  runs_on: node_runtime
  paths: "docs/**/*.md"
}

component ReleaseWorkflow {
  runs_on: github_actions
  paths: ".github/workflows/release.yml"
}

component DocsWorkflow {
  runs_on: github_actions
  paths: ".github/workflows/docs.yml"
}

component VscodeExtension {
  runs_on: node_runtime
  paths: "editors/vscode-aglang/src/**/*.ts"
}

component Tests {
  runs_on: node_runtime
  paths: "tests/**/*.ts"
}

component ArchitectureSpec {
  runs_on: node_runtime
  paths: "architecture.ag"
}

component CompiledArchitecture {
  runs_on: node_runtime
  paths: "architecture.o"
}

component AgentContext {
  runs_on: node_runtime
  paths: "AGENTS.md"
}

component SkillManifest {
  runs_on: node_runtime
  paths: "skill.json"
}

component SemanticQueries {
  runs_on: node_runtime
  paths: ".aglang/extractors/**/*.agq.yml"
}

invariant CompilerEntrypointBoundary {
  deny flow LanguageFrontend -> CliCompiler
  deny flow SmtBackend -> CliCompiler
  deny flow RuntimeGate -> CliCompiler
  deny flow ExtractorAnalyzers -> CliCompiler
  deny flow GraphProjection -> CliCompiler
  deny flow Emitters -> CliCompiler
  deny flow SpecGenerator -> CliCompiler
}

invariant SmtBackendIsolation {
  deny flow SmtBackend -> RuntimeGate
  deny flow SmtBackend -> ExtractorAnalyzers
  deny flow SmtBackend -> GraphProjection
}

invariant LanguageFrontendPurity {
  deny flow LanguageFrontend -> RuntimeGate
  deny flow LanguageFrontend -> GraphProjection
  deny flow LanguageFrontend -> Emitters
}

invariant ExtractorAnalyzerBoundary {
  deny flow ExtractorAnalyzers -> CliCompiler
  deny flow ExtractorAnalyzers -> Emitters
}

invariant VscodeApiBoundary {
  deny flow VscodeExtension -> RuntimeGate
  deny flow VscodeExtension -> ExtractorAnalyzers
  deny flow VscodeExtension -> SmtBackend
  deny flow VscodeExtension -> GraphProjection
}

workflow_policy ReleaseSafety {
  allow publish ReleaseWorkflow -> npm_registry when tag "v*.*.*"
  allow release ReleaseWorkflow -> github_releases when tag "v*.*.*"
  allow deploy DocsWorkflow -> github_pages when branch "master"
  deny publish * -> npm_registry when pull_request
  deny release * -> github_releases when pull_request
  deny deploy * -> github_pages when pull_request
  require before ReleaseWorkflow "npm run typecheck" -> "npm publish"
  require before ReleaseWorkflow "npm run build" -> "npm publish"
  require before ReleaseWorkflow "npm test" -> "npm publish"
  require before ReleaseWorkflow "npm pack --dry-run" -> "npm publish"
  require before ReleaseWorkflow "npm run docs:build" -> "npm publish"
  deny permission * contents: write when pull_request
}

change_policy DocsFreshness {
  require touched CliReferenceDocs when touched CliCompiler
  require touched ReadmeDocs when touched CliCompiler
  require touched CliReferenceDocs when touched PackageMetadata
  require touched ReadmeDocs when touched PackageMetadata
  require touched AgentSkill when touched PackageMetadata
  require touched AgentSkill when touched AgentSkillInstaller
  require touched PublicDocs when touched AgentSkill
  require touched ArchitectureSpec when touched LanguageFrontend
  require touched ArchitectureSpec when touched RuntimeGate
  require touched ArchitectureSpec when touched SmtBackend
  require touched ArchitectureSpec when touched Emitters
  require touched CompiledArchitecture when touched ArchitectureSpec
  require touched AgentContext when touched ArchitectureSpec
  require touched SkillManifest when touched ArchitectureSpec
  require touched PublicDocs when touched ArchitectureSpec
  require touched AgentSkill when touched ArchitectureSpec
  require touched PublicDocs when touched SemanticQueries
  require touched AgentSkill when touched SemanticQueries
}
