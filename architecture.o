    "; === value policy rules ===",
    "; --- ConsentExampleCartShape ---",
    "(declare-const FieldPath__ConsentExampleSharedCart__items__length FieldPath)",
    "(declare-const Relation__eqeq ValueRelation)",
    "(declare-const Value__1 ScalarValue)",
    "(declare-const FieldPath__ConsentExampleSharedCart__phase FieldPath)",
    "(declare-const Value__SingleItem ScalarValue)",
    "(assert (=> (and (ValueFact ConsentExampleSharedCart FieldPath__ConsentExampleSharedCart__phase Relation__eqeq Value__SingleItem) (ValueContradiction ConsentExampleSharedCart FieldPath__ConsentExampleSharedCart__items__length Relation__eqeq Value__1)) false))",
    "(declare-const FieldPath__ConsentExampleOrder__total FieldPath)",
    "(declare-const Relation__gteq ValueRelation)",
    "(declare-const Value__0 ScalarValue)",
    "(assert (=> (ValueContradiction ConsentExampleOrder FieldPath__ConsentExampleOrder__total Relation__gteq Value__0) false))",
    "(declare-const FieldPath__ConsentExampleUserSession__gdprAccepted FieldPath)",
    "(declare-const Value__true ScalarValue)",
    "(assert (=> (ValueContradiction ConsentExampleUserSession FieldPath__ConsentExampleUserSession__gdprAccepted Relation__eqeq Value__true) false))",
    "",
    "; === operation policy rules ===",
    "; --- ConsentExampleSubmitOrderRules ---",
    "(declare-const Operation__submitOrder Operation)",
    "(assert (=> (OperationStateContradiction Operation__submitOrder Phase__before ConsentExampleSharedCart FieldPath__ConsentExampleSharedCart__phase Relation__eqeq Value__SingleItem) false))",
    "(declare-const FieldPath__ConsentExampleOrder__status FieldPath)",
    "(declare-const Value__Submitted ScalarValue)",
    "(assert (=> (OperationStateContradiction Operation__submitOrder Phase__after ConsentExampleOrder FieldPath__ConsentExampleOrder__status Relation__eqeq Value__Submitted) false))",
    "",
    "; === event policy rules ===",
    "; --- ConsentExampleProtocol ---",
    "(declare-const Event__AcceptConsent EventType)",
    "(declare-const Event__ShowConsent EventType)",
    "(assert (=> (EventMissingPrecedence Event__AcceptConsent Event__ShowConsent ConsentExampleUserSession) false))",
    ""
  ],
