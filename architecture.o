  "workflowPolicies": [
    {
      "name": "ReleaseSafety",
      "rules": [
        {
          "kind": "ActionRule",
          "effect": "allow",
          "action": "publish",
          "workflow": "ReleaseWorkflow",
          "target": "npm_registry",
          "when": {
            "kind": "tag",
            "value": "v*.*.*"
          }
        },
        {
          "kind": "ActionRule",
          "effect": "allow",
          "action": "release",
          "workflow": "ReleaseWorkflow",
          "target": "github_releases",
          "when": {
            "kind": "tag",
            "value": "v*.*.*"
          }
        },
        {
          "kind": "ActionRule",
          "effect": "allow",
          "action": "deploy",
          "workflow": "DocsWorkflow",
          "target": "github_pages",
          "when": {
            "kind": "branch",
            "value": "master"
          }
        },
        {
          "kind": "ActionRule",
          "effect": "deny",
          "action": "publish",
          "workflow": "*",
          "target": "npm_registry",
          "when": {
            "kind": "pull_request"
          }
        },
        {
          "kind": "ActionRule",
          "effect": "deny",
          "action": "release",
          "workflow": "*",
          "target": "github_releases",
          "when": {
            "kind": "pull_request"
          }
        },
        {
          "kind": "ActionRule",
          "effect": "deny",
          "action": "deploy",
          "workflow": "*",
          "target": "github_pages",
          "when": {
            "kind": "pull_request"
          }
        },
        {
          "kind": "BeforeRule",
          "workflow": "ReleaseWorkflow",
          "before": "npm run typecheck",
          "after": "npm publish"
        },
        {
          "kind": "BeforeRule",
          "workflow": "ReleaseWorkflow",
          "before": "npm run build",
          "after": "npm publish"
        },
        {
          "kind": "BeforeRule",
          "workflow": "ReleaseWorkflow",
          "before": "npm test",
          "after": "npm publish"
        },
        {
          "kind": "BeforeRule",
          "workflow": "ReleaseWorkflow",
          "before": "npm pack --dry-run",
          "after": "npm publish"
        },
        {
          "kind": "BeforeRule",
          "workflow": "ReleaseWorkflow",
          "before": "npm run docs:build",
          "after": "npm publish"
        },
        {
          "kind": "PermissionRule",
          "effect": "deny",
          "workflow": "*",
          "permission": "contents",
          "access": "write",
          "when": {
            "kind": "pull_request"
          }
        }
      ]
    }
  ],
  "changePolicies": [
    {
      "name": "DocsFreshness",
