  "dataTypes": [
    {
      "name": "AglcUiConfig",
      "fields": [
        {
          "key": "projectRoot",
          "typeExpr": "String"
        },
        {
          "key": "artifact",
          "typeExpr": "String"
        }
      ]
    },
    {
      "name": "AglcUiRun",
      "fields": [
        {
          "key": "id",
          "typeExpr": "String"
        }
      ]
    },
    {
      "name": "AglcUiFile",
      "fields": [
        {
          "key": "path",
          "typeExpr": "String"
        },
        {
          "key": "content",
          "typeExpr": "String"
        }
      ]
    },
    {
      "name": "AglcUiRunCreated",
      "fields": [
        {
          "key": "id",
          "typeExpr": "String"
        }
      ]
    },
    {
      "name": "ConsentExampleUserSession",
      "fields": [
        {
          "key": "consent",
          "typeExpr": "ConsentStatus"
        },
        {
          "key": "gdprAccepted",
          "typeExpr": "Bool"
        }
      ]
    },
    {
      "name": "ConsentExampleSharedCart",
      "fields": [
        {
          "key": "phase",
          "typeExpr": "CartPhase"
        },
        {
          "key": "items",
          "typeExpr": "List<String>"
        }
      ]
    },
    {
      "name": "ConsentExampleOrder",
      "fields": [
        {
          "key": "status",
          "typeExpr": "ConsentExampleOrderStatus"
        },
        {
          "key": "total",
          "typeExpr": "Money"
        }
      ]
    },
    {
      "name": "StripeOrder",
      "fields": [
        {
          "key": "id",
          "typeExpr": "UUID"
        },
        {
          "key": "status",
          "typeExpr": "OrderStatus"
        },
        {
          "key": "stripe_payment_intent_id",
          "typeExpr": "Optional<String>"
        }
      ]
    }
  ],
  "stateMachines": [
    {
      "name": "ConsentExampleConsentLifecycle",
      "onType": "ConsentExampleUserSession",
      "onField": "consent",
      "transitions": [
        {
          "kind": "allow",
          "from": "Unknown",
          "to": "Presented"
        },
        {
          "kind": "allow",
          "from": "Presented",
          "to": "Accepted"
        },
        {
          "kind": "allow",
          "from": "Presented",
          "to": "Rejected"
        },
        {
          "kind": "deny",
          "from": "Unknown",
          "to": "Accepted"
        },
        {
          "kind": "deny",
          "from": "Unknown",
          "to": "Rejected"
        }
      ]
    },
    {
      "name": "ConsentExampleCartProtocol",
      "onType": "ConsentExampleSharedCart",
      "onField": "phase",
      "transitions": [
        {
          "kind": "allow",
          "from": "Empty",
          "to": "SingleItem"
        },
        {
          "kind": "allow",
          "from": "SingleItem",
          "to": "MultiItem"
        },
        {
          "kind": "deny",
          "from": "Empty",
          "to": "MultiItem"
        }
      ]
    },
    {
      "name": "StripeOrderLifecycle",
      "onType": "StripeOrder",
      "onField": "status",
      "transitions": [
        {
          "kind": "allow",
          "from": "Created",
          "to": "PendingPayment"
        },
        {
          "kind": "allow",
          "from": "PendingPayment",
          "to": "Paid"
        },
        {
          "kind": "allow",
          "from": "PendingPayment",
          "to": "Cancelled"
        },
        {
          "kind": "allow",
          "from": "Paid",
          "to": "FulfillmentQueued"
        },
        {
          "kind": "allow",
          "from": "FulfillmentQueued",
          "to": "Fulfilled"
        },
        {
          "kind": "allow",
          "from": "Paid",
          "to": "Refunded"
        },
        {
          "kind": "deny",
          "from": "Created",
          "to": "Paid"
        },
        {
          "kind": "deny",
          "from": "Created",
          "to": "Fulfilled"
        },
        {
          "kind": "deny",
          "from": "PendingPayment",
          "to": "Fulfilled"
        },
        {
          "kind": "deny",
          "from": "Cancelled",
          "to": "*"
        },
        {
          "kind": "deny",
          "from": "Refunded",
          "to": "*"
        }
      ]
    }
  ],
  "valuePolicies": [
    {
      "name": "ConsentExampleCartShape",
      "rules": [
        {
          "kind": "RequireValue",
          "requirement": {
            "subject": "ConsentExampleSharedCart",
            "path": [
              "items",
              "length"
            ],
            "relation": "==",
            "value": 1
          },
          "when": {
            "subject": "ConsentExampleSharedCart",
            "path": [
              "phase"
            ],
            "relation": "==",
            "value": "SingleItem"
          }
        },
        {
          "kind": "RequireValue",
          "requirement": {
            "subject": "ConsentExampleOrder",
            "path": [
              "total"
            ],
            "relation": ">=",
            "value": 0
          }
        },
        {
          "kind": "RequireValue",
          "requirement": {
            "subject": "ConsentExampleUserSession",
            "path": [
              "gdprAccepted"
            ],
            "relation": "==",
            "value": true
          }
        }
      ]
    }
  ],
  "operationPolicies": [
    {
      "name": "ConsentExampleSubmitOrderRules",
      "rules": [
        {
          "kind": "RequireBefore",
          "operation": "submitOrder",
          "requirement": {
            "subject": "ConsentExampleSharedCart",
            "path": [
              "phase"
            ],
            "relation": "==",
            "value": "SingleItem"
          }
        },
        {
          "kind": "EnsureAfter",
          "operation": "submitOrder",
          "requirement": {
            "subject": "ConsentExampleOrder",
            "path": [
              "status"
            ],
            "relation": "==",
            "value": "Submitted"
          }
        }
      ]
    }
  ],
  "eventPolicies": [
    {
      "name": "ConsentExampleProtocol",
      "rules": [
        {
          "kind": "RequirePrecededBy",
          "event": "AcceptConsent",
          "precededBy": "ShowConsent",
          "scope": "ConsentExampleUserSession"
        }
      ]
    }
  ],
