  "enforcement": [
    {
      "declaration": "invariant deny flow",
      "level": "formal_z3",
      "mechanism": "Flow facts extracted from code are asserted against SMT-LIB constraints."
    },
    {
      "declaration": "invariant deny dataflow",
      "level": "formal_z3",
      "mechanism": "Dataflow facts inferred from handled data and extracted reachability are asserted against SMT-LIB constraints."
    },
    {
      "declaration": "invariant deny reach",
      "level": "formal_z3",
      "mechanism": "Transitive flow reachability facts extracted from code are asserted against SMT-LIB constraints."
    },
    {
      "declaration": "data_policy",
      "level": "formal_z3",
      "mechanism": "Classified and jurisdictional data reachability facts are asserted against SMT-LIB constraints."
    },
    {
      "declaration": "trust_policy",
      "level": "formal_z3",
      "mechanism": "Trust boundary facts are checked against extracted reachability, data classification, and declared auth metadata."
    },
    {
      "declaration": "permission",
      "level": "formal_z3",
      "mechanism": "Extracted protected operations are checked for matching role evidence where extractors can prove authorization facts."
    },
    {
      "declaration": "change_policy",
      "level": "formal_z3",
      "mechanism": "Touched-component facts are asserted against SMT-LIB implication rules."
    },
    {
      "declaration": "di_policy",
      "level": "formal_z3",
      "mechanism": "Constructor-injection, lifetime, and service-locator facts are asserted against SMT-LIB constraints."
    },
    {
      "declaration": "contract",
      "level": "deterministic_policy",
      "mechanism": "Route extractors compare implemented and consumed endpoints against declared contracts."
    },
    {
      "declaration": "workflow_policy",
      "level": "deterministic_policy",
      "mechanism": "GitHub Actions facts are checked for publish/deploy/release, permissions, and step order."
    },
    {
      "declaration": "invariant require encryption",
      "level": "advisory",
      "mechanism": "Reported as warnings because extractors do not yet prove encryption."
    },
    {
      "declaration": "machine",
      "level": "advisory",
      "mechanism": "Emitted to AGENTS.md for agent guidance; transition extraction is not enforced yet."
    }
  ],
  "constraints": [
    "; === aglang base sorts ===",
    "(declare-sort Entity 0)",
    "(declare-sort DataType 0)",
    "(declare-sort ServiceType 0)",
    "(declare-sort Classification 0)",
    "(declare-sort Jurisdiction 0)",
    "(declare-sort Operation 0)",
    "(declare-sort RoleType 0)",
    "(declare-datatype Lifetime ((Lifetime__singleton) (Lifetime__scoped) (Lifetime__transient)))",
    "(declare-fun Flow      (Entity Entity) Bool)",
    "(declare-fun CanReach  (Entity Entity) Bool)",
    "(declare-fun DataFlow  (DataType Entity) Bool)",
    "(declare-fun DataCanReach (DataType Entity) Bool)",
    "(declare-fun ClassifiedAs (DataType Classification) Bool)",
    "(declare-fun JurisdictionOf (DataType Jurisdiction) Bool)",
    "(declare-fun Injects   (Entity Entity) Bool)",
    "(declare-fun InjectReach (Entity Entity) Bool)",
    "(declare-fun LifetimeDepends (Lifetime Lifetime) Bool)",
    "(declare-fun LifetimeReach (Lifetime Lifetime) Bool)",
    "(declare-fun Resolves  (Entity ServiceType) Bool)",
    "(declare-fun RequiresAuth (Entity Entity) Bool)",
    "(declare-fun Performs (Entity Operation DataType) Bool)",
    "(declare-fun ChecksRole (Entity RoleType) Bool)",
    "(declare-fun Encrypted (Entity Entity) Bool)",
    "(declare-fun Trusted   (Entity) Bool)",
    "(declare-fun IsNode    (Entity) Bool)",
    "(declare-fun IsComp    (Entity) Bool)",
    "(declare-fun IsResource (Entity) Bool)",
    "",
    "; === node declarations ===",
    "(declare-const node_runtime Entity)",
    "(assert (IsNode node_runtime))",
    "(assert (= (Trusted node_runtime) true))",
    "(declare-const github_actions Entity)",
    "(assert (IsNode github_actions))",
    "(assert (= (Trusted github_actions) true))",
    "(declare-const npm_registry Entity)",
    "(assert (IsNode npm_registry))",
    "(assert (= (Trusted npm_registry) true))",
    "(declare-const github_pages Entity)",
    "(assert (IsNode github_pages))",
    "(assert (= (Trusted github_pages) true))",
    "(declare-const github_releases Entity)",
    "(assert (IsNode github_releases))",
    "(assert (= (Trusted github_releases) true))",
    "",
    "; === component declarations ===",
    "(declare-const CliCompiler Entity)",
    "(assert (IsComp CliCompiler))",
    "(declare-const LanguageFrontend Entity)",
    "(assert (IsComp LanguageFrontend))",
    "(declare-const SmtBackend Entity)",
    "(assert (IsComp SmtBackend))",
    "(declare-const RuntimeGate Entity)",
    "(assert (IsComp RuntimeGate))",
    "(declare-const ExtractorAnalyzers Entity)",
    "(assert (IsComp ExtractorAnalyzers))",
    "(declare-const GraphProjection Entity)",
    "(assert (IsComp GraphProjection))",
    "(declare-const Emitters Entity)",
    "(assert (IsComp Emitters))",
    "(declare-const SpecGenerator Entity)",
    "(assert (IsComp SpecGenerator))",
    "(declare-const DocsSite Entity)",
    "(assert (IsComp DocsSite))",
    "(declare-const PackageMetadata Entity)",
    "(assert (IsComp PackageMetadata))",
    "(declare-const AgentSkill Entity)",
    "(assert (IsComp AgentSkill))",
    "(declare-const AgentSkillInstaller Entity)",
    "(assert (IsComp AgentSkillInstaller))",
    "(declare-const ReadmeDocs Entity)",
    "(assert (IsComp ReadmeDocs))",
    "(declare-const CliReferenceDocs Entity)",
    "(assert (IsComp CliReferenceDocs))",
    "(declare-const PublicDocs Entity)",
    "(assert (IsComp PublicDocs))",
    "(declare-const ReleaseWorkflow Entity)",
    "(assert (IsComp ReleaseWorkflow))",
    "(declare-const DocsWorkflow Entity)",
    "(assert (IsComp DocsWorkflow))",
    "(declare-const VscodeExtension Entity)",
    "(assert (IsComp VscodeExtension))",
    "(declare-const Tests Entity)",
    "(assert (IsComp Tests))",
    "",
