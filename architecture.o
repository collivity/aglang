  "mappings": {
    "CliCompiler": "src/index.ts",
    "LanguageFrontend": "src/{ast,checker,importer,import-openapi,import-tf,lexer,parser}.ts",
    "SmtBackend": "src/smt/**/*.ts",
    "RuntimeGate": "src/runtime/{contract-gate,delta-assert,diff-parser,diagnostic,extraction-cache,gate}.ts",
    "ExtractorAnalyzers": "src/analyzers/**/*.ts",
    "GraphProjection": "src/runtime/graph-projection.ts",
    "Emitters": "src/emitters/**/*.ts",
    "SpecGenerator": "src/generate.ts",
    "DocsSite": "{docs,site,scripts}/**/*.{md,ts,js,mjs}",
    "PackageMetadata": "{package.json,package-lock.json}",
    "AgentSkill": "skills/aglang/SKILL.md",
    "AgentSkillInstaller": "scripts/postinstall-agent-skill.mjs",
    "ReadmeDocs": "README.md",
    "CliReferenceDocs": "docs/cli/reference.md",
    "PublicDocs": "docs/**/*.md",
    "ReleaseWorkflow": ".github/workflows/release.yml",
    "DocsWorkflow": ".github/workflows/docs.yml",
    "VscodeExtension": "editors/vscode-aglang/src/**/*.ts",
    "Tests": "tests/**/*.ts"
  },
