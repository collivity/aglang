    "; === state machine transition rules ===",
    "; --- ConsentExampleConsentLifecycle ---",
    "(declare-const Field__ConsentExampleUserSession__consent Field)",
    "(declare-const State__ConsentStatus__Unknown StateValue)",
    "(declare-const State__ConsentStatus__Presented StateValue)",
    "(declare-const State__ConsentStatus__Accepted StateValue)",
    "(declare-const State__ConsentStatus__Rejected StateValue)",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Unknown State__ConsentStatus__Accepted) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Unknown State__ConsentStatus__Rejected) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Presented State__ConsentStatus__Unknown) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Accepted State__ConsentStatus__Unknown) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Accepted State__ConsentStatus__Presented) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Accepted State__ConsentStatus__Rejected) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Rejected State__ConsentStatus__Unknown) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Rejected State__ConsentStatus__Presented) false))",
    "(assert (=> (Transition ConsentExampleUserSession Field__ConsentExampleUserSession__consent State__ConsentStatus__Rejected State__ConsentStatus__Accepted) false))",
    "; --- ConsentExampleCartProtocol ---",
    "(declare-const Field__ConsentExampleSharedCart__phase Field)",
    "(declare-const State__CartPhase__Empty StateValue)",
    "(declare-const State__CartPhase__SingleItem StateValue)",
    "(declare-const State__CartPhase__MultiItem StateValue)",
    "(assert (=> (Transition ConsentExampleSharedCart Field__ConsentExampleSharedCart__phase State__CartPhase__Empty State__CartPhase__MultiItem) false))",
    "(assert (=> (Transition ConsentExampleSharedCart Field__ConsentExampleSharedCart__phase State__CartPhase__SingleItem State__CartPhase__Empty) false))",
    "(assert (=> (Transition ConsentExampleSharedCart Field__ConsentExampleSharedCart__phase State__CartPhase__MultiItem State__CartPhase__Empty) false))",
    "(assert (=> (Transition ConsentExampleSharedCart Field__ConsentExampleSharedCart__phase State__CartPhase__MultiItem State__CartPhase__SingleItem) false))",
