{
  "name": "@collivity/aglang",
  "version": "0.1.0",
  "description": "Architecture Ground Language — dual-compiler system that enforces architectural rules against real code at git-commit time using Z3 SMT solving",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aglc": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "architecture",
    "compiler",
    "z3",
    "smt",
    "devtools",
    "agents",
    "guardrails",
    "git-hook",
    "static-analysis",
    "architecture-as-code"
  ],
  "author": "aglang contributors",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/collivity/aglang"
  },
  "homepage": "https://collivity.github.io/aglang",
  "bugs": {
    "url": "https://github.com/collivity/aglang/issues"
  },
  "files": [
    "dist",
    "stdlib",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@types/micromatch": "^4.0.10",
    "micromatch": "^4.0.8",
    "z3-solver": "^4.16.0"
  }
}
