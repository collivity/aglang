{
  "name": "@collivity/aglang",
  "version": "0.2.2",
  "description": "Architecture Ground Language — agent-facing architecture validation for continuous coding feedback and Z3-backed enforcement",
  "type": "module",
  "main": "build/aglc.js",
  "bin": {
    "aglc": "build/aglc.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall-agent-skill.mjs",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "arch:compile": "node build/aglc.js compile architecture.ag --out architecture.o",
    "arch:check": "node build/aglc.js check --arch architecture.o --project . --all",
    "arch:graph": "node build/aglc.js graph --arch architecture.o --project . --all --json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run typecheck && npm run build && npm test && npm run arch:check"
  },
  "keywords": [
    "architecture",
    "compiler",
    "z3",
    "smt",
    "devtools",
    "agents",
    "guardrails",
    "git-hook",
    "static-analysis",
    "architecture-as-code"
  ],
  "author": "aglang contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/collivity/aglang.git"
  },
  "homepage": "https://collivity.github.io/aglang",
  "bugs": {
    "url": "https://github.com/collivity/aglang/issues"
  },
  "files": [
    "build/aglc.js",
    "scripts/postinstall-agent-skill.mjs",
    "skills",
    "stdlib",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@types/micromatch": "^4.0.10",
    "micromatch": "^4.0.8",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c-sharp": "^0.21.3",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-typescript": "^0.21.1",
    "yaml": "^2.9.0",
    "z3-solver": "^4.16.0"
  }
}
